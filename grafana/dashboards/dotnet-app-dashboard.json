{
  "id": null,
  "uid": "dotnet-app-overview",
  "title": ".NET App Overview",
  "tags": ["dotnet", "reusable"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(up{job=\"dotnet-apps\"}, app)",
        "refresh": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [

    { "id": 100, "type": "row", "title": "🟢 Service Health", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    {
      "id": 1, "title": "Service Status", "type": "stat",
      "description": "1 = UP, 0 = DOWN. Based on whether Prometheus can reach the app.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "up{job=\"dotnet-apps\", app=\"$app\"}" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
        { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
      ] } }
    },
    {
      "id": 4, "title": "Process Uptime", "type": "stat",
      "description": "How long the app has been running since last restart.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "time() - process_start_time_seconds{app=\"$app\"}" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2, "title": "Total Requests (all time)", "type": "stat",
      "description": "Cumulative count of every HTTP request received.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "sum(http_requests_received_total{app=\"$app\"})" }],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3, "title": "Active Requests Right Now", "type": "stat",
      "description": "Requests currently being processed, not yet responded to.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "sum(http_requests_in_progress{app=\"$app\"})" }],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 6, "title": "5xx Error Rate", "type": "gauge",
      "description": "Percentage of requests failing with server errors (500-599) over the last 5 minutes. Y-axis: 0-100%.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "100 * sum(rate(http_requests_received_total{app=\"$app\", code=~\"5..\"}[5m])) / sum(rate(http_requests_received_total{app=\"$app\"}[5m]))" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 1 },
        { "color": "red", "value": 5 }
      ] } } }
    },
    {
      "id": 5, "title": "Thread Count", "type": "stat",
      "description": "Current number of OS threads used by the process.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "process_num_threads{app=\"$app\"}" }],
      "options": { "colorMode": "value", "graphMode": "none" }
    },

    { "id": 101, "type": "row", "title": "🌐 HTTP Traffic", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },

    {
      "id": 7, "title": "Requests Per Second", "type": "timeseries",
      "description": "X-axis: time. Y-axis: requests handled per second.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "sum(rate(http_requests_received_total{app=\"$app\"}[1m]))", "legendFormat": "requests/sec" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "axisLabel": "Requests / sec", "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "id": 8, "title": "Request Duration Percentiles", "type": "timeseries",
      "description": "X-axis: time. Y-axis: response time in seconds. p50 = median, p95/p99 = worst-case tail latency.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"$app\"}[5m])) by (le))", "legendFormat": "p50 (median)" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"$app\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"$app\"}[5m])) by (le))", "legendFormat": "p99 (worst case)" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "axisLabel": "Response time (seconds)", "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 9, "title": "Status Code Distribution", "type": "piechart",
      "description": "Proportion of responses by HTTP status code over the selected time range.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [{ "expr": "sum by (code) (increase(http_requests_received_total{app=\"$app\"}[$__range]))", "legendFormat": "{{code}}" }],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "id": 10, "title": "Requests by HTTP Method", "type": "barchart",
      "description": "X-axis: HTTP method (GET/POST/PUT/DELETE). Y-axis: requests per second, averaged over last 5 min.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "targets": [{ "expr": "sum by (method) (rate(http_requests_received_total{app=\"$app\"}[5m]))", "legendFormat": "{{method}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "axisLabel": "Requests / sec" } } }
    },
    {
      "id": 11, "title": "In-Progress Requests Over Time", "type": "timeseries",
      "description": "X-axis: time. Y-axis: number of requests currently being handled (not yet completed).",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "targets": [{ "expr": "sum(http_requests_in_progress{app=\"$app\"})", "legendFormat": "in-progress" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Active requests", "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "id": 12, "title": "Request & Response Size (p95)", "type": "timeseries",
      "description": "X-axis: time. Y-axis: body size in bytes/KB. p95 means 95% of requests/responses were smaller than this.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_size_bytes_bucket{app=\"$app\"}[5m])) by (le))", "legendFormat": "request size (p95)" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_response_size_bytes_bucket{app=\"$app\"}[5m])) by (le))", "legendFormat": "response size (p95)" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "Payload size", "drawStyle": "line", "fillOpacity": 10 } } }
    },

    { "id": 102, "type": "row", "title": "⚙️ Process & Runtime", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 } },

    {
      "id": 14, "title": "CPU Usage", "type": "gauge",
      "description": "Current CPU consumption as a percentage of one core. Y-axis: 0-100%.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 31 },
      "targets": [{ "expr": "100 * rate(process_cpu_seconds_total{app=\"$app\"}[1m])" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 60 },
        { "color": "red", "value": 85 }
      ] } } }
    },
    {
      "id": 15, "title": "Memory Usage", "type": "gauge",
      "description": "Working set memory (physical RAM actually in use) in MB.",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 31 },
      "targets": [{ "expr": "process_working_set_bytes{app=\"$app\"} / 1024 / 1024" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes", "min": 0, "max": 1024, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 512 },
        { "color": "red", "value": 800 }
      ] } } }
    },
    {
      "id": 16, "title": "CPU & Memory Over Time", "type": "timeseries",
      "description": "X-axis: time. Left Y-axis: CPU %. Right Y-axis: Memory MB.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "targets": [
        { "expr": "100 * rate(process_cpu_seconds_total{app=\"$app\"}[1m])", "legendFormat": "CPU %" },
        { "expr": "process_working_set_bytes{app=\"$app\"} / 1024 / 1024", "legendFormat": "Memory MB" }
      ],
      "fieldConfig": { "defaults": { "custom": { "axisLabel": "CPU % / Memory MB", "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 17, "title": "Virtual Memory", "type": "stat",
      "description": "Total virtual address space reserved by the process (usually much larger than physical RAM used).",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 39 },
      "targets": [{ "expr": "process_virtual_memory_bytes{app=\"$app\"} / 1024 / 1024" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 18, "title": "GC Collections by Generation", "type": "barchart",
      "description": "X-axis: GC generation (0 = frequent/cheap, 2 = rare/expensive). Y-axis: collections per second over last 5 min.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 39 },
      "targets": [
        { "expr": "rate(dotnet_collection_count_total{app=\"$app\", generation=\"0\"}[5m])", "legendFormat": "Gen 0" },
        { "expr": "rate(dotnet_collection_count_total{app=\"$app\", generation=\"1\"}[5m])", "legendFormat": "Gen 1" },
        { "expr": "rate(dotnet_collection_count_total{app=\"$app\", generation=\"2\"}[5m])", "legendFormat": "Gen 2" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Collections / sec" } } }
    },
    { "id": 103, "type": "row", "title": "🗄️ Database (PostgreSQL)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 } },

{
  "id": 20, "title": "PostgreSQL Status", "type": "stat",
  "description": "1 = reachable, 0 = down.",
  "gridPos": { "h": 4, "w": 4, "x": 0, "y": 56 },
  "targets": [{ "expr": "pg_up" }],
  "options": { "colorMode": "background", "graphMode": "none" },
  "fieldConfig": { "defaults": { "mappings": [
    { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
    { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
  ] } }
},
{
  "id": 21, "title": "Active Connections", "type": "stat",
  "description": "Current number of open connections to Postgres.",
  "gridPos": { "h": 4, "w": 4, "x": 4, "y": 56 },
  "targets": [{ "expr": "sum(pg_stat_database_numbackends)" }],
  "options": { "colorMode": "value", "graphMode": "none" }
},
{
  "id": 22, "title": "Cache Hit Ratio", "type": "gauge",
  "description": "% of reads served from memory vs disk. Should stay near 99%+; a drop means your data no longer fits in cache.",
  "gridPos": { "h": 4, "w": 4, "x": 8, "y": 56 },
  "targets": [{ "expr": "100 * sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))" }],
  "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [
    { "color": "red", "value": null },
    { "color": "yellow", "value": 90 },
    { "color": "green", "value": 99 }
  ] } } }
},
{
  "id": 23, "title": "Transaction Rollback Rate", "type": "stat",
  "description": "Rollbacks per second. A rising trend often signals application-level errors or bad queries.",
  "gridPos": { "h": 4, "w": 4, "x": 12, "y": 56 },
  "targets": [{ "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))" }],
  "fieldConfig": { "defaults": { "unit": "reqps" } },
  "options": { "colorMode": "value", "graphMode": "none" }
},
{
  "id": 24, "title": "Locks Held", "type": "stat",
  "description": "Current lock count across all modes. Sudden spikes can indicate contention.",
  "gridPos": { "h": 4, "w": 4, "x": 16, "y": 56 },
  "targets": [{ "expr": "sum(pg_locks_count)" }],
  "options": { "colorMode": "value", "graphMode": "none" }
},
{
  "id": 25, "title": "Transactions Per Second (Commit vs Rollback)", "type": "timeseries",
  "description": "X-axis: time. Y-axis: transactions/sec. Healthy systems show mostly commits, minimal rollbacks.",
  "gridPos": { "h": 8, "w": 12, "x": 0, "y": 60 },
  "targets": [
    { "expr": "sum(rate(pg_stat_database_xact_commit[1m]))", "legendFormat": "commits/sec" },
    { "expr": "sum(rate(pg_stat_database_xact_rollback[1m]))", "legendFormat": "rollbacks/sec" }
  ],
  "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "axisLabel": "Transactions / sec" } } }
},
{
  "id": 26, "title": "Rows Read vs Fetched", "type": "timeseries",
  "description": "X-axis: time. Y-axis: rows/sec. 'Returned' is scanned, 'Fetched' is actually used — a big gap can indicate inefficient queries scanning more than needed.",
  "gridPos": { "h": 8, "w": 12, "x": 12, "y": 60 },
  "targets": [
    { "expr": "sum(rate(pg_stat_database_tup_returned[5m]))", "legendFormat": "rows returned" },
    { "expr": "sum(rate(pg_stat_database_tup_fetched[5m]))", "legendFormat": "rows fetched" }
  ],
  "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Rows / sec" } } }
}
  ]
}